<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="006" author="dev">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="schedule_entries" columnName="date"/>
            </not>
        </preConditions>
        <addColumn tableName="schedule_entries">
            <column name="date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="shift_type" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="shift_start" type="TIME"/>
            <column name="shift_end" type="TIME"/>
            <column name="notes" type="VARCHAR(500)"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>