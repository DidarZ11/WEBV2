<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.17.xsd">

    <changeSet id="009-add-telephony-tables" author="crm-system">

        <createTable tableName="operator_status">
            <column name="user_id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="is_online" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="last_active" type="TIMESTAMP"/>
        </createTable>

        <createTable tableName="call_requests">
            <column name="id" type="BIGSERIAL" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="client_phone" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)" defaultValue="NEW"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="operator_id" type="BIGINT"/>
        </createTable>

        <addForeignKeyConstraint baseColumnNames="user_id" baseTableName="operator_status"
                                 constraintName="fk_operator_status_user"
                                 referencedColumnNames="id" referencedTableName="users"/>

        <addForeignKeyConstraint baseColumnNames="operator_id" baseTableName="call_requests"
                                 constraintName="fk_call_requests_operator"
                                 referencedColumnNames="id" referencedTableName="users"/>
    </changeSet>

</databaseChangeLog>