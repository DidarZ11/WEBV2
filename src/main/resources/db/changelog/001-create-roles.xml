<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                       http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="001-1" author="didar">
        <createTable tableName="roles">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="description" type="VARCHAR(255)"/>
        </createTable>
    </changeSet>

    <changeSet id="001-2" author="didar">
        <createTable tableName="authorities">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false" unique="true"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="001-3" author="didar">
        <createTable tableName="roles_to_authorities">
            <column name="role_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="authority_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="roles_to_authorities"
                       columnNames="role_id,authority_id"/>
        <addForeignKeyConstraint
                baseTableName="roles_to_authorities" baseColumnNames="role_id"
                referencedTableName="roles" referencedColumnNames="id"
                constraintName="fk_rta_role"/>
        <addForeignKeyConstraint
                baseTableName="roles_to_authorities" baseColumnNames="authority_id"
                referencedTableName="authorities" referencedColumnNames="id"
                constraintName="fk_rta_authority"/>
    </changeSet>

</databaseChangeLog>